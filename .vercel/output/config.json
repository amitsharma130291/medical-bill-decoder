{
	"version": 3,
	"routes": [
		{
			"handle": "filesystem"
		},
		{
			"src": "^/_astro/(.*)$",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable"
			},
			"continue": true
		},
		{
			"src": "^/_server-islands/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/_image/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/create-checkout/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/decode-eob/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/webhooks/lemonsqueezy/?$",
			"dest": "_render"
		},
		{
			"src": "^/billing-errors/?$",
			"dest": "_render"
		},
		{
			"src": "^/dispute-letter/?$",
			"dest": "_render"
		},
		{
			"src": "^/eob-decoder/?$",
			"dest": "_render"
		},
		{
			"src": "^/success/?$",
			"dest": "_render"
		},
		{
			"src": "^/$",
			"dest": "_render"
		}
	]
}
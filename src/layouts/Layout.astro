---
export interface Props {
  title: string;
  description?: string;
  image?: string;
  canonicalUrl?: string;
}

const { title, description = 'Decode your medical bills, dispute errors, and fight back against overcharges with free AI-powered tools.', image, canonicalUrl } = Astro.props;
const canonicalURL = canonicalUrl ?? new URL(Astro.url.pathname, Astro.site).href;
const ogImage = image ?? `${import.meta.env.SITE_URL ?? 'https://eobdecoder.com'}/og-image.svg`;
const gaMeasurementId = import.meta.env.GA_MEASUREMENT_ID ?? '';

---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  <meta name="robots" content="index, follow" />
  <title>{title} | Medical Bill Decoder</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="Medical Bill Decoder" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:image" content={ogImage} />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />


  {gaMeasurementId && (
    <Fragment>
      <script async src={`https://www.googletagmanager.com/gtag/js?id=${gaMeasurementId}`}></script>
      <script define:vars={{ gaMeasurementId }}>
        window.dataLayer = window.dataLayer || [];
        function gtag(){ dataLayer.push(arguments); }
        gtag('js', new Date());
        gtag('config', gaMeasurementId);
      </script>
    </Fragment>
  )}
</head>
<body class="min-h-screen font-sans text-ink" style="background-color: #F7F8FA;">

  <!-- Navbar -->
  <nav class="bg-white border-b border-[#E2E8F0] sticky top-0 z-50">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-16">
        <a href="/" class="flex items-center gap-2 font-bold text-xl text-[#0F7B8C] hover:text-[#0a6475] transition-colors">
          <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
          </svg>
          Medical Bill Decoder
        </a>
        <div class="hidden md:flex items-center gap-7">
          <a href="/eob-decoder" class="text-[#64748B] hover:text-[#0F7B8C] font-medium text-sm transition-colors">EOB Decoder</a>
          <a href="/dispute-letter" class="text-[#64748B] hover:text-[#0F7B8C] font-medium text-sm transition-colors">Dispute Letter</a>
          <a href="/billing-errors" class="text-[#64748B] hover:text-[#0F7B8C] font-medium text-sm transition-colors">Billing Errors</a>
          <a href="/eob-decoder" class="bg-[#2D4A7A] text-white px-4 py-2 rounded-lg text-sm font-semibold hover:bg-[#243D66] transition-colors">
            Get Started Free
          </a>
        </div>
        <button id="mobile-menu-btn" class="md:hidden p-2 rounded-md text-[#64748B] hover:text-ink hover:bg-[#F7F8FA]">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </button>
      </div>
    </div>
    <div id="mobile-menu" class="hidden md:hidden border-t border-[#E2E8F0] bg-white px-4 py-3 space-y-1">
      <a href="/eob-decoder" class="block px-3 py-2 rounded-md text-[#64748B] hover:bg-[#F7F8FA] font-medium text-sm">EOB Decoder</a>
      <a href="/dispute-letter" class="block px-3 py-2 rounded-md text-[#64748B] hover:bg-[#F7F8FA] font-medium text-sm">Dispute Letter</a>
      <a href="/billing-errors" class="block px-3 py-2 rounded-md text-[#64748B] hover:bg-[#F7F8FA] font-medium text-sm">Billing Errors</a>
    </div>
  </nav>

  <!-- Main content -->
  <main class="flex-1">
    <slot />
  </main>

  <!-- Footer -->
  <footer class="bg-white border-t border-[#E2E8F0] mt-16">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div>
          <div class="font-bold text-lg text-[#0F7B8C] mb-3">Medical Bill Decoder</div>
          <p class="text-[#64748B] text-sm leading-relaxed">Free tools to decode medical bills, dispute errors, and fight back against overcharges.</p>
        </div>
        <div>
          <div class="font-semibold text-ink text-sm mb-3 uppercase tracking-wide" style="font-size: 12px; letter-spacing: 0.05em;">Tools</div>
          <ul class="space-y-2 text-sm text-[#64748B]">
            <li><a href="/eob-decoder" class="hover:text-[#0F7B8C] transition-colors">EOB Decoder</a></li>
            <li><a href="/dispute-letter" class="hover:text-[#0F7B8C] transition-colors">Dispute Letter Generator</a></li>
            <li><a href="/billing-errors" class="hover:text-[#0F7B8C] transition-colors">Billing Error Checklist</a></li>
          </ul>
        </div>
        <div>
          <div class="font-semibold text-ink text-sm mb-3 uppercase tracking-wide" style="font-size: 12px; letter-spacing: 0.05em;">Disclaimer</div>
          <p class="text-[#64748B] text-sm leading-relaxed">This tool provides educational information only and is not legal or medical advice. Always consult a healthcare advocate or attorney for complex disputes.</p>
        </div>
      </div>
      <div class="mt-8 pt-8 border-t border-[#E2E8F0] text-center text-[#64748B] text-sm">
        &copy; {new Date().getFullYear()} Medical Bill Decoder. Educational purposes only.
      </div>
    </div>
  </footer>

  <script>
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    if (btn && menu) {
      btn.addEventListener('click', () => menu.classList.toggle('hidden'));
    }
  </script>

  <!-- Coming Soon waitlist modal -->
  <div id="coming-soon-modal" style="display:none; position:fixed; inset:0; z-index:9999; background:rgba(15,23,42,0.65); backdrop-filter:blur(4px);" role="dialog" aria-modal="true" aria-labelledby="cs-modal-title">
    <div style="position:absolute; top:50%; left:50%; transform:translate(-50%,-50%); background:#fff; border-radius:20px; padding:40px 36px; max-width:440px; width:calc(100% - 32px); box-shadow:0 24px 64px rgba(15,23,42,0.18); text-align:center;">
      <button id="cs-close-btn" style="position:absolute; top:16px; right:16px; background:none; border:none; cursor:pointer; color:#94A3B8; font-size:22px; line-height:1;" aria-label="Close">&times;</button>
      <div style="width:52px; height:52px; background:#D0EFF3; border-radius:14px; display:flex; align-items:center; justify-content:center; margin:0 auto 16px;">
        <svg width="26" height="26" fill="none" stroke="#0F7B8C" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/><path d="M12 6v6l4 2"/></svg>
      </div>
      <h2 id="cs-modal-title" style="font-family:'DM Sans',sans-serif; font-size:22px; font-weight:700; color:#1A2332; margin:0 0 8px;">Complete Dispute Kit — Coming Soon</h2>
      <p style="font-size:14px; color:#64748B; line-height:1.6; margin:0 0 24px;">We're putting the finishing touches on the Complete Dispute Kit. Drop your email and you'll be the first to know when it launches — plus get an early-bird discount.</p>
      <form id="cs-waitlist-form" style="display:flex; flex-direction:column; gap:12px;">
        <input id="cs-email-input" type="email" required placeholder="you@example.com" style="width:100%; box-sizing:border-box; padding:12px 16px; border:1.5px solid #E2E8F0; border-radius:10px; font-size:15px; color:#1A2332; outline:none; font-family:inherit;" />
        <button type="submit" style="background:#E8A020; color:#1A2332; font-weight:700; font-size:15px; padding:13px 24px; border:none; border-radius:10px; cursor:pointer; font-family:inherit; transition:background 0.15s;" onmouseover="this.style.background='#D4901A'" onmouseout="this.style.background='#E8A020'">
          Notify Me at Launch
        </button>
      </form>
      <div id="cs-success-msg" style="display:none; margin-top:16px; padding:12px 16px; background:#D1FAE5; border-radius:10px; color:#065F46; font-size:14px; font-weight:500;">
        &#10003; You're on the list! We'll email you when we launch.
      </div>
      <p style="margin-top:16px; font-size:12px; color:#94A3B8;">No spam. Unsubscribe anytime.</p>
    </div>
  </div>

  <script>
    // Coming Soon modal logic
    (function () {
      var modal = document.getElementById('coming-soon-modal');
      var closeBtn = document.getElementById('cs-close-btn');
      var form = document.getElementById('cs-waitlist-form');
      var emailInput = document.getElementById('cs-email-input');
      var successMsg = document.getElementById('cs-success-msg');

      function showComingSoon(e) {
        if (e) e.preventDefault();
        modal.style.display = 'block';
        emailInput.value = '';
        form.style.display = 'flex';
        successMsg.style.display = 'none';
        setTimeout(function () { emailInput.focus(); }, 50);
      }

      function closeModal() {
        modal.style.display = 'none';
      }

      // Intercept all links pointing to /api/create-checkout
      document.addEventListener('click', function (e) {
        var anchor = e.target.closest('a[href="/api/create-checkout"]');
        if (!anchor) return;
        showComingSoon(e);
      });

      // Close on X button
      closeBtn.addEventListener('click', closeModal);

      // Close on backdrop click
      modal.addEventListener('click', function (e) {
        if (e.target === modal) closeModal();
      });

      // Close on Escape key
      document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape' && modal.style.display === 'block') closeModal();
      });

      // Handle form submission
      form.addEventListener('submit', function (e) {
        e.preventDefault();
        var email = emailInput.value.trim();
        if (!email) return;
        // Store in localStorage as a lightweight capture
        try {
          var leads = JSON.parse(localStorage.getItem('mbd_waitlist') || '[]');
          if (!leads.includes(email)) leads.push(email);
          localStorage.setItem('mbd_waitlist', JSON.stringify(leads));
        } catch (_) {}
        form.style.display = 'none';
        successMsg.style.display = 'block';
      });
    })();
  </script>
</body>
</html>

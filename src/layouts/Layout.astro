---
export interface Props {
  title: string;
  description?: string;
  image?: string;
  canonicalUrl?: string;
}

const { title, description = 'Decode your medical bills, dispute errors, and fight back against overcharges with free AI-powered tools.', image, canonicalUrl } = Astro.props;
const canonicalURL = canonicalUrl ?? new URL(Astro.url.pathname, Astro.site).href;
const ogImage = image ?? `${import.meta.env.SITE_URL ?? 'https://eobdecoder.com'}/og-image.svg`;
const gaMeasurementId = import.meta.env.GA_MEASUREMENT_ID ?? '';
const isVercelPreview = Astro.url.hostname.includes('.vercel.app');

---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  <meta name="robots" content="index, follow" />
  {isVercelPreview && <meta name="robots" content="noindex, nofollow" />}
  <title>{title} | Medical Bill Decoder</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="Medical Bill Decoder" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:image" content={ogImage} />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />


  {gaMeasurementId && (
    <Fragment>
      <script async src={`https://www.googletagmanager.com/gtag/js?id=${gaMeasurementId}`}></script>
      <script define:vars={{ gaMeasurementId }}>
        window.dataLayer = window.dataLayer || [];
        function gtag(){ dataLayer.push(arguments); }
        gtag('js', new Date());
        gtag('config', gaMeasurementId);
      </script>
    </Fragment>
  )}
</head>
<body class="min-h-screen font-sans text-ink" style="background-color: #F7F8FA;">

  <!-- Navbar -->
  <nav class="bg-white border-b border-[#E2E8F0] sticky top-0 z-50">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-16">
        <a href="/" class="flex items-center gap-2 font-bold text-xl text-[#0F7B8C] hover:text-[#0a6475] transition-colors">
          <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
          </svg>
          Medical Bill Decoder
        </a>
        <div class="hidden md:flex items-center gap-7">
          <a href="/eob-decoder" class="text-[#64748B] hover:text-[#0F7B8C] font-medium text-sm transition-colors">EOB Decoder</a>
          <a href="/dispute-letter" class="text-[#64748B] hover:text-[#0F7B8C] font-medium text-sm transition-colors">Dispute Letter</a>
          <a href="/billing-errors" class="text-[#64748B] hover:text-[#0F7B8C] font-medium text-sm transition-colors">Billing Errors</a>
          <a href="/eob-decoder" class="bg-[#2D4A7A] text-white px-4 py-2 rounded-lg text-sm font-semibold hover:bg-[#243D66] transition-colors">
            Get Started Free
          </a>
        </div>
        <button id="mobile-menu-btn" class="md:hidden p-2 rounded-md text-[#64748B] hover:text-ink hover:bg-[#F7F8FA]">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </button>
      </div>
    </div>
    <div id="mobile-menu" class="hidden md:hidden border-t border-[#E2E8F0] bg-white px-4 py-3 space-y-1">
      <a href="/eob-decoder" class="block px-3 py-2 rounded-md text-[#64748B] hover:bg-[#F7F8FA] font-medium text-sm">EOB Decoder</a>
      <a href="/dispute-letter" class="block px-3 py-2 rounded-md text-[#64748B] hover:bg-[#F7F8FA] font-medium text-sm">Dispute Letter</a>
      <a href="/billing-errors" class="block px-3 py-2 rounded-md text-[#64748B] hover:bg-[#F7F8FA] font-medium text-sm">Billing Errors</a>
    </div>
  </nav>

  <!-- Main content -->
  <main class="flex-1">
    <slot />
  </main>

  <!-- Footer -->
  <footer class="bg-white border-t border-[#E2E8F0] mt-16">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div>
          <div class="font-bold text-lg text-[#0F7B8C] mb-3">Medical Bill Decoder</div>
          <p class="text-[#64748B] text-sm leading-relaxed">Free tools to decode medical bills, dispute errors, and fight back against overcharges.</p>
        </div>
        <div>
          <div class="font-semibold text-ink text-sm mb-3 uppercase tracking-wide" style="font-size: 12px; letter-spacing: 0.05em;">Tools</div>
          <ul class="space-y-2 text-sm text-[#64748B]">
            <li><a href="/eob-decoder" class="hover:text-[#0F7B8C] transition-colors">EOB Decoder</a></li>
            <li><a href="/dispute-letter" class="hover:text-[#0F7B8C] transition-colors">Dispute Letter Generator</a></li>
            <li><a href="/billing-errors" class="hover:text-[#0F7B8C] transition-colors">Billing Error Checklist</a></li>
          </ul>
        </div>
        <div>
          <div class="font-semibold text-ink text-sm mb-3 uppercase tracking-wide" style="font-size: 12px; letter-spacing: 0.05em;">Disclaimer</div>
          <p class="text-[#64748B] text-sm leading-relaxed">This tool provides educational information only and is not legal or medical advice. Always consult a healthcare advocate or attorney for complex disputes.</p>
        </div>
      </div>
      <div class="mt-8 pt-8 border-t border-[#E2E8F0] text-center text-[#64748B] text-sm">
        &copy; {new Date().getFullYear()} Medical Bill Decoder. Educational purposes only.
      </div>
    </div>
  </footer>

  <script>
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    if (btn && menu) {
      btn.addEventListener('click', () => menu.classList.toggle('hidden'));
    }
  </script>

  <!-- Paddle Checkout — code preserved, gated by PAYMENTS_LIVE flag -->
  <!-- To re-enable payments: set PAYMENTS_LIVE = true below (one-line change) -->
  <script src="https://cdn.paddle.com/paddle/v2/paddle.js"></script>
  <script define:vars={{
    paddleToken: import.meta.env.PADDLE_CLIENT_TOKEN ?? 'test_251f58a7eb4defd755ce96bf2ae',
    paddleEnv: import.meta.env.PADDLE_ENVIRONMENT ?? 'sandbox',
    paddlePriceId: import.meta.env.PADDLE_PRICE_ID ?? 'pri_01kxk93szzx7sxvk3emdsw6cqv',
    siteUrl: import.meta.env.SITE_URL ?? 'https://eobdecoder.com'
  }}>
    // PAYMENTS_LIVE: set to true to re-enable live checkout. One-line change.
    var PAYMENTS_LIVE = false;

    // Initialize Paddle
    function initPaddle() {
      if (typeof Paddle === 'undefined') return;
      if (paddleEnv === 'sandbox') Paddle.Environment.set('sandbox');
      Paddle.Initialize({
        token: paddleToken,
        eventCallback: function(data) {
          if (data.name === 'checkout.completed') {
            document.cookie = 'paid=true; max-age=' + (365 * 24 * 60 * 60) + '; path=/; SameSite=Lax';
            window.location.href = siteUrl + '/success';
          }
        }
      });
    }
    if (PAYMENTS_LIVE) {
      initPaddle();
      document.addEventListener('DOMContentLoaded', initPaddle);
    }

    // Capture-phase delegation — fires BEFORE browser follows the link
    // Only active when PAYMENTS_LIVE = true
    if (PAYMENTS_LIVE) {
      document.addEventListener('click', function(e) {
        const target = e.target.closest('a[href="/api/create-checkout"], button[data-checkout]');
        if (!target) return;
        e.preventDefault();
        e.stopPropagation();
        if (typeof Paddle === 'undefined') { console.warn('Paddle not loaded'); return; }
        Paddle.Checkout.open({
          items: [{ priceId: paddlePriceId, quantity: 1 }],
          settings: { successUrl: siteUrl + '/success', displayMode: 'overlay', theme: 'light', allowLogout: false }
        });
      }, true); // <-- true = capture phase, critical
    }
  </script>
</body>
</html>

---
export interface Props {
  title: string;
  description?: string;
  image?: string;
  canonicalUrl?: string;
}

const { title, description = 'Decode your medical bills, dispute errors, and fight back against overcharges with free AI-powered tools.', image, canonicalUrl } = Astro.props;
const canonicalURL = canonicalUrl ?? new URL(Astro.url.pathname, Astro.site).href;
const ogImage = image ?? `${import.meta.env.SITE_URL ?? 'https://eobdecoder.com'}/og-image.svg`;
const gaMeasurementId = import.meta.env.GA_MEASUREMENT_ID ?? '';
const isVercelPreview = Astro.url.hostname.includes('.vercel.app');

---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  <meta name="robots" content="index, follow" />
  {isVercelPreview && <meta name="robots" content="noindex, nofollow" />}
  <title>{title} | Medical Bill Decoder</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="Medical Bill Decoder" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:image" content={ogImage} />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />


  {gaMeasurementId && (
    <Fragment>
      <script async src={`https://www.googletagmanager.com/gtag/js?id=${gaMeasurementId}`}></script>
      <script define:vars={{ gaMeasurementId }}>
        window.dataLayer = window.dataLayer || [];
        function gtag(){ dataLayer.push(arguments); }
        gtag('js', new Date());
        gtag('config', gaMeasurementId);
      </script>
    </Fragment>
  )}
</head>
<body class="min-h-screen font-sans text-ink" style="background-color: #F7F8FA;">

  <!-- Navbar -->
  <nav class="bg-white border-b border-[#E2E8F0] sticky top-0 z-50">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-16">
        <a href="/" class="flex items-center gap-2 font-bold text-xl text-[#0F7B8C] hover:text-[#0a6475] transition-colors">
          <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
          </svg>
          Medical Bill Decoder
        </a>
        <div class="hidden md:flex items-center gap-7">
          <a href="/eob-decoder" class="text-[#64748B] hover:text-[#0F7B8C] font-medium text-sm transition-colors">EOB Decoder</a>
          <a href="/dispute-letter" class="text-[#64748B] hover:text-[#0F7B8C] font-medium text-sm transition-colors">Dispute Letter</a>
          <a href="/billing-errors" class="text-[#64748B] hover:text-[#0F7B8C] font-medium text-sm transition-colors">Billing Errors</a>
          <a href="/eob-decoder" class="bg-[#2D4A7A] text-white px-4 py-2 rounded-lg text-sm font-semibold hover:bg-[#243D66] transition-colors">
            Get Started Free
          </a>
        </div>
        <button id="mobile-menu-btn" class="md:hidden p-2 rounded-md text-[#64748B] hover:text-ink hover:bg-[#F7F8FA]">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </button>
      </div>
    </div>
    <div id="mobile-menu" class="hidden md:hidden border-t border-[#E2E8F0] bg-white px-4 py-3 space-y-1">
      <a href="/eob-decoder" class="block px-3 py-2 rounded-md text-[#64748B] hover:bg-[#F7F8FA] font-medium text-sm">EOB Decoder</a>
      <a href="/dispute-letter" class="block px-3 py-2 rounded-md text-[#64748B] hover:bg-[#F7F8FA] font-medium text-sm">Dispute Letter</a>
      <a href="/billing-errors" class="block px-3 py-2 rounded-md text-[#64748B] hover:bg-[#F7F8FA] font-medium text-sm">Billing Errors</a>
    </div>
  </nav>

  <!-- Main content -->
  <main class="flex-1">
    <slot />
  </main>

  <!-- Footer -->
  <footer class="bg-white border-t border-[#E2E8F0] mt-16">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div>
          <div class="font-bold text-lg text-[#0F7B8C] mb-3">Medical Bill Decoder</div>
          <p class="text-[#64748B] text-sm leading-relaxed">Free tools to decode medical bills, dispute errors, and fight back against overcharges.</p>
        </div>
        <div>
          <div class="font-semibold text-ink text-sm mb-3 uppercase tracking-wide" style="font-size: 12px; letter-spacing: 0.05em;">Tools</div>
          <ul class="space-y-2 text-sm text-[#64748B]">
            <li><a href="/eob-decoder" class="hover:text-[#0F7B8C] transition-colors">EOB Decoder</a></li>
            <li><a href="/dispute-letter" class="hover:text-[#0F7B8C] transition-colors">Dispute Letter Generator</a></li>
            <li><a href="/billing-errors" class="hover:text-[#0F7B8C] transition-colors">Billing Error Checklist</a></li>
          </ul>
        </div>
        <div>
          <div class="font-semibold text-ink text-sm mb-3 uppercase tracking-wide" style="font-size: 12px; letter-spacing: 0.05em;">Disclaimer</div>
          <p class="text-[#64748B] text-sm leading-relaxed">This tool provides educational information only and is not legal or medical advice. Always consult a healthcare advocate or attorney for complex disputes.</p>
        </div>
      </div>
      <div class="mt-8 pt-8 border-t border-[#E2E8F0] text-center text-[#64748B] text-sm">
        &copy; {new Date().getFullYear()} Medical Bill Decoder. Educational purposes only.
      </div>
    </div>
  </footer>

  <script>
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    if (btn && menu) {
      btn.addEventListener('click', () => menu.classList.toggle('hidden'));
    }
  </script>


  <!-- Coming Soon Modal -->
  <div id="coming-soon-modal" style="display:none; position:fixed; inset:0; z-index:1000; background:rgba(0,0,0,0.55); align-items:center; justify-content:center;">
    <div style="background:#fff; border-radius:16px; padding:36px 32px; max-width:440px; width:90%; position:relative; box-shadow:0 24px 64px rgba(0,0,0,0.18);">
      <!-- Close button -->
      <button onclick="document.getElementById('coming-soon-modal').style.display='none'"
        style="position:absolute; top:14px; right:16px; background:none; border:none; cursor:pointer; color:#64748B; font-size:22px; line-height:1;" aria-label="Close">&#x2715;</button>

      <!-- Teal rocket icon -->
      <div style="width:52px; height:52px; border-radius:14px; background:#D0EFF3; display:flex; align-items:center; justify-content:center; margin-bottom:18px;">
        <svg style="width:28px;height:28px;" fill="none" stroke="#0F7B8C" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
          <path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/>
          <path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/>
          <path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"/>
          <path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"/>
        </svg>
      </div>

      <h2 style="font-size:20px; font-weight:700; color:#1A2332; margin:0 0 8px;">Complete Dispute Kit &mdash; Coming Soon</h2>
      <p style="font-size:14px; color:#64748B; margin:0 0 20px; line-height:1.5;">Enter your email and we&rsquo;ll notify you the moment it goes live.</p>

      <div id="cs-form-wrap">
        <form id="cs-form" style="display:flex; gap:8px; flex-wrap:wrap;">
          <input id="cs-email" type="email" required placeholder="you@example.com"
            style="flex:1; min-width:0; padding:11px 14px; border:1.5px solid #CBD5E1; border-radius:10px; font-size:15px; color:#1A2332; font-family:'DM Sans',sans-serif; outline:none;" />
          <button type="submit"
            style="padding:11px 18px; background:#E8A020; color:#1A2332; font-weight:700; border:none; border-radius:10px; font-size:15px; cursor:pointer; white-space:nowrap; font-family:'DM Sans',sans-serif;">
            Notify Me &rarr;
          </button>
        </form>
      </div>
      <div id="cs-success" style="display:none; color:#0F7B8C; font-weight:600; font-size:15px; padding:10px 0;">
        &#10003; You will be notified once it is live
      </div>
    </div>
  </div>

  <script>
    // Show Coming Soon modal
    function showComingSoon(e) {
      if (e) { e.preventDefault(); e.stopPropagation(); }
      var modal = document.getElementById('coming-soon-modal');
      if (modal) { modal.style.display = 'flex'; }
    }

    // Capture-phase delegation: intercept a[href="/api/create-checkout"] clicks
    document.addEventListener('click', function(e) {
      var target = e.target && e.target.closest ? e.target.closest('a[href="/api/create-checkout"]') : null;
      if (!target) return;
      showComingSoon(e);
    }, true);

    // Close modal on backdrop click
    document.getElementById('coming-soon-modal').addEventListener('click', function(e) {
      if (e.target === this) this.style.display = 'none';
    });

    // Waitlist form submit
    document.getElementById('cs-form').addEventListener('submit', function(e) {
      e.preventDefault();
      var email = document.getElementById('cs-email').value.trim();
      var btn = this.querySelector('button[type="submit"]');
      btn.disabled = true;
      btn.textContent = 'Sending...';

      fetch('/api/waitlist', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email: email }),
      })
        .then(function(r) { return r.json(); })
        .then(function(data) {
          if (data.success) {
            document.getElementById('cs-form-wrap').style.display = 'none';
            document.getElementById('cs-success').style.display = 'block';
          } else {
            btn.disabled = false;
            btn.textContent = 'Notify Me →';
            alert(data.error || 'Something went wrong. Please try again.');
          }
        })
        .catch(function() {
          btn.disabled = false;
          btn.textContent = 'Notify Me →';
          alert('Network error. Please try again.');
        });
    });
  </script>
</body>
</html>
---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Contact — EOB Decoder" description="Get in touch with the EOB Decoder team. We typically respond within 2 business days.">

  <!-- Hero -->
  <section style="background: linear-gradient(135deg, #0F7B8C 0%, #2D4A7A 100%);" class="text-white py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h1 class="font-bold mb-4 leading-tight" style="font-size: 40px;">Contact Us</h1>
      <p class="text-blue-100" style="font-size: 18px; line-height: 1.6;">We're here to help. Send us an email and we'll get back to you within 2 business days.</p>
    </div>
  </section>

  <!-- Content -->
  <section class="py-16 px-4">
    <div class="max-w-4xl mx-auto">

      <div class="bg-white border border-[#E2E8F0] rounded-2xl p-8 mb-8 shadow-sm">
        <div class="flex items-start gap-4">
          <div class="bg-[#F0FAFB] rounded-xl p-3 flex-shrink-0">
            <svg class="w-6 h-6 text-[#0F7B8C]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
          </div>
          <div>
            <h2 class="font-bold text-[#1A2332] mb-2" style="font-size: 18px;">Email</h2>
            <a href="mailto:amitsharma00261@gmail.com" class="text-[#0F7B8C] hover:underline font-medium" style="font-size: 16px;">amitsharma00261@gmail.com</a>
            <p class="text-[#64748B] text-sm mt-1">We aim to respond within 2 business days.</p>
          </div>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
        <div class="bg-white border border-[#E2E8F0] rounded-2xl p-6 shadow-sm">
          <h3 class="font-bold text-[#1A2332] mb-3" style="font-size: 16px;">Billing Issues</h3>
          <p class="text-[#64748B] text-sm leading-relaxed">If you have a billing or payment question, please include your order reference number in your email so we can look up your account quickly.</p>
        </div>
        <div class="bg-white border border-[#E2E8F0] rounded-2xl p-6 shadow-sm">
          <h3 class="font-bold text-[#1A2332] mb-3" style="font-size: 16px;">Tool Issues</h3>
          <p class="text-[#64748B] text-sm leading-relaxed">Experiencing a problem with one of our tools? Please describe the issue in as much detail as possible, including the tool you were using and what happened.</p>
        </div>
      </div>

      <div class="bg-[#F8FAFC] border border-[#E2E8F0] rounded-xl p-6">
        <p class="text-[#64748B] text-sm leading-relaxed">EOB Decoder is an independent tool built to help US patients understand their medical bills. We are not affiliated with any insurance company, hospital, or healthcare provider. For urgent medical or legal matters, please consult a qualified professional.</p>
      </div>

    </div>
  </section>

</Layout>

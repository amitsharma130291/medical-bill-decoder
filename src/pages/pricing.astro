---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Pricing — Medical Bill Decoder"
  description="Simple, honest pricing for Medical Bill Decoder. Free tools forever, plus a Dispute Kit and Complete Access for serious disputes."
  canonicalUrl="https://eobdecoder.com/pricing"
>

  <!-- Hero -->
  <section style="background: linear-gradient(135deg, #0F7B8C 0%, #0a6475 100%);" class="py-16 px-4 text-center text-white">
    <div class="max-w-3xl mx-auto">
      <h1 class="font-bold mb-4" style="font-size: 40px; line-height: 1.15;">Simple, Honest Pricing</h1>
      <p class="text-teal-100 mb-2" style="font-size: 18px; line-height: 1.6;">
        Start free. Upgrade only when you need more firepower.
      </p>
      <p class="text-teal-200" style="font-size: 14px;">No subscriptions. No surprises. No gotchas.</p>
    </div>
  </section>

  <!-- Pricing Cards -->
  <section class="py-16 px-4" style="background: #F7F8FA;">
    <div class="max-w-5xl mx-auto">

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

        <!-- Free Tier -->
        <div style="background:#fff; border:1.5px solid #E2E8F0; border-radius:16px; padding:32px 28px; position:relative; display:flex; flex-direction:column;">
          <div style="font-size:13px; font-weight:600; color:#64748B; text-transform:uppercase; letter-spacing:0.07em; margin-bottom:12px;">Free</div>
          <div style="font-size:42px; font-weight:800; color:#1A2332; line-height:1; margin-bottom:6px;">$0</div>
          <div style="font-size:14px; color:#64748B; margin-bottom:24px;">Forever free</div>
          <ul style="list-style:none; padding:0; margin:0 0 32px; flex:1;">
            <li style="display:flex; align-items:flex-start; gap:10px; margin-bottom:12px; font-size:14px; color:#334155;">
              <span style="color:#0F7B8C; font-weight:700; margin-top:1px;">✓</span>
              <span>EOB Decoder — 3 decodes per day</span>
            </li>
            <li style="display:flex; align-items:flex-start; gap:10px; margin-bottom:12px; font-size:14px; color:#334155;">
              <span style="color:#0F7B8C; font-weight:700; margin-top:1px;">✓</span>
              <span>Dispute Letter Generator — 3 letters per day</span>
            </li>
            <li style="display:flex; align-items:flex-start; gap:10px; margin-bottom:12px; font-size:14px; color:#334155;">
              <span style="color:#0F7B8C; font-weight:700; margin-top:1px;">✓</span>
              <span>Billing Error Checklist (full access)</span>
            </li>
            <li style="display:flex; align-items:flex-start; gap:10px; margin-bottom:12px; font-size:14px; color:#334155;">
              <span style="color:#0F7B8C; font-weight:700; margin-top:1px;">✓</span>
              <span>No account required</span>
            </li>
          </ul>
          <a href="/eob-decoder" style="display:block; text-align:center; padding:13px 20px; border:2px solid #0F7B8C; border-radius:10px; color:#0F7B8C; font-weight:700; font-size:15px; text-decoration:none; transition:background 0.15s;" onmouseover="this.style.background='#F0FAFB'" onmouseout="this.style.background='transparent'">
            Start Free →
          </a>
        </div>

        <!-- Dispute Kit -->
        <div style="background:#fff; border:2px solid #0F7B8C; border-radius:16px; padding:32px 28px; position:relative; display:flex; flex-direction:column; box-shadow: 0 8px 32px rgba(15,123,140,0.12);">
          <!-- Live badge -->
          <div style="position:absolute; top:-12px; left:50%; transform:translateX(-50%); background:#059669; color:#fff; font-size:12px; font-weight:700; padding:4px 14px; border-radius:999px; white-space:nowrap; letter-spacing:0.04em;">
            NOW LIVE
          </div>
          <div style="font-size:13px; font-weight:600; color:#0F7B8C; text-transform:uppercase; letter-spacing:0.07em; margin-bottom:12px;">Dispute Kit</div>
          <!-- Urgency badge -->
          <div style="display:inline-block; background:#FEF3C7; color:#92400E; font-size:11px; font-weight:700; padding:3px 10px; border-radius:999px; margin-bottom:10px; width:fit-content;">🔥 Introductory Price</div>
          <div style="display:flex; align-items:baseline; gap:10px; margin-bottom:4px;">
            <span style="font-size:42px; font-weight:800; color:#1A2332; line-height:1;">$29</span>
            <span style="font-size:18px; color:#94A3B8; text-decoration:line-through;">$39</span>
          </div>
          <div style="font-size:13px; color:#92400E; font-weight:600; margin-bottom:4px;">Price increases as we add more features</div>
          <div style="font-size:14px; color:#64748B; margin-bottom:24px;">One-time payment</div>
          <ul style="list-style:none; padding:0; margin:0 0 32px; flex:1;">
            <li style="display:flex; align-items:flex-start; gap:10px; margin-bottom:12px; font-size:14px; color:#334155;">
              <span style="color:#0F7B8C; font-weight:700; margin-top:1px;">✓</span>
              <span>Everything in Free</span>
            </li>
            <li style="display:flex; align-items:flex-start; gap:10px; margin-bottom:12px; font-size:14px; color:#334155;">
              <span style="color:#0F7B8C; font-weight:700; margin-top:1px;">✓</span>
              <span>20 EOB decodes per day</span>
            </li>
            <li style="display:flex; align-items:flex-start; gap:10px; margin-bottom:12px; font-size:14px; color:#334155;">
              <span style="color:#0F7B8C; font-weight:700; margin-top:1px;">✓</span>
              <span>20 dispute letters per day</span>
            </li>
            <li style="display:flex; align-items:flex-start; gap:10px; margin-bottom:12px; font-size:14px; color:#334155;">
              <span style="color:#0F7B8C; font-weight:700; margin-top:1px;">✓</span>
              <span>Customizable letter templates</span>
            </li>
            <li style="display:flex; align-items:flex-start; gap:10px; margin-bottom:12px; font-size:14px; color:#334155;">
              <span style="color:#0F7B8C; font-weight:700; margin-top:1px;">✓</span>
              <span>State-specific dispute guides</span>
            </li>
            <li style="display:flex; align-items:flex-start; gap:10px; margin-bottom:12px; font-size:14px; color:#334155;">
              <span style="color:#0F7B8C; font-weight:700; margin-top:1px;">✓</span>
              <span>Step-by-step appeal instructions</span>
            </li>
          </ul>
          <a href="https://amitverse58.gumroad.com/l/fsupd" target="_blank" rel="noopener"
            style="display:block; text-align:center; padding:13px 20px; background:#0F7B8C; border-radius:10px; color:#fff; font-weight:700; font-size:15px; text-decoration:none;"
            onmouseover="this.style.background='#0a6475'" onmouseout="this.style.background='#0F7B8C'"
            onclick="if(typeof gtag!=='undefined'){gtag('event','gumroad_buy_click',{event_category:'conversion',event_label:'dispute_kit_pricing',value:29})}">
            Buy Now — $29 →
          </a>
          <a href="/activate" style="display:block; text-align:center; padding:10px 20px; color:#64748B; font-size:13px; font-weight:600; text-decoration:none; margin-top:10px;">
            Already purchased? Activate key →
          </a>
        </div>

        <!-- Complete Access -->
        <div style="background:#fff; border:1.5px solid #E2E8F0; border-radius:16px; padding:32px 28px; position:relative; display:flex; flex-direction:column;">
          <div style="font-size:13px; font-weight:600; color:#64748B; text-transform:uppercase; letter-spacing:0.07em; margin-bottom:12px;">Complete Access</div>
          <!-- Urgency badge -->
          <div style="display:inline-block; background:#FEF3C7; color:#92400E; font-size:11px; font-weight:700; padding:3px 10px; border-radius:999px; margin-bottom:10px; width:fit-content;">🔥 Launch Price</div>
          <div style="font-size:42px; font-weight:800; color:#1A2332; line-height:1; margin-bottom:4px;">$49</div>
          <div style="font-size:13px; color:#92400E; font-weight:600; margin-bottom:4px;">Lock in this rate now — price rises with new features</div>
          <div style="font-size:14px; color:#64748B; margin-bottom:6px;">One-time payment</div>
          <div style="font-size:13px; color:#0F7B8C; font-weight:600; margin-bottom:24px;">$34/year launching with payments</div>
          <ul style="list-style:none; padding:0; margin:0 0 32px; flex:1;">
            <li style="display:flex; align-items:flex-start; gap:10px; margin-bottom:12px; font-size:14px; color:#334155;">
              <span style="color:#0F7B8C; font-weight:700; margin-top:1px;">✓</span>
              <span>Everything in Dispute Kit</span>
            </li>
            <li style="display:flex; align-items:flex-start; gap:10px; margin-bottom:12px; font-size:14px; color:#334155;">
              <span style="color:#0F7B8C; font-weight:700; margin-top:1px;">✓</span>
              <span>Unlimited EOB decodes</span>
            </li>
            <li style="display:flex; align-items:flex-start; gap:10px; margin-bottom:12px; font-size:14px; color:#334155;">
              <span style="color:#0F7B8C; font-weight:700; margin-top:1px;">✓</span>
              <span>Unlimited dispute letters</span>
            </li>
            <li style="display:flex; align-items:flex-start; gap:10px; margin-bottom:12px; font-size:14px; color:#334155;">
              <span style="color:#0F7B8C; font-weight:700; margin-top:1px;">✓</span>
              <span>Priority processing</span>
            </li>
            <li style="display:flex; align-items:flex-start; gap:10px; margin-bottom:12px; font-size:14px; color:#334155;">
              <span style="color:#0F7B8C; font-weight:700; margin-top:1px;">✓</span>
              <span>All future features included</span>
            </li>
            <li style="display:flex; align-items:flex-start; gap:10px; margin-bottom:12px; font-size:14px; color:#334155;">
              <span style="color:#0F7B8C; font-weight:700; margin-top:1px;">✓</span>
              <span>Founding member pricing locked forever</span>
            </li>
          </ul>
          <a href="https://amitverse58.gumroad.com/l/rslhtn" target="_blank" rel="noopener"
            style="display:block; text-align:center; padding:13px 20px; background:#0F7B8C; border-radius:10px; color:#fff; font-weight:700; font-size:15px; text-decoration:none;"
            onmouseover="this.style.background='#0a6475'" onmouseout="this.style.background='#0F7B8C'"
            onclick="if(typeof gtag!=='undefined'){gtag('event','gumroad_buy_click',{event_category:'conversion',event_label:'complete_access_pricing',value:49})}">
            Buy Now — $49 →
          </a>
          <a href="/activate" style="display:block; text-align:center; padding:10px 20px; color:#64748B; font-size:13px; font-weight:600; text-decoration:none; margin-top:10px;">
            Already purchased? Activate key →
          </a>
        </div>

      </div>

      <!-- Annual note -->
      <p style="text-align:center; color:#64748B; font-size:14px; margin-top:24px;">
        Annual plan launching with payments at <strong>$34/year</strong> — founding members get the best rate, first 100 only.
      </p>

    </div>
  </section>

  <!-- Waitlist form -->
  <section style="background:#fff; border-top:1px solid #E2E8F0;" class="py-14 px-4">
    <div class="max-w-lg mx-auto text-center">
      <h2 class="font-bold mb-3" style="font-size:24px; color:#1A2332;">Join the Waitlist</h2>
      <p style="color:#64748B; font-size:15px; margin-bottom:24px; line-height:1.6;">
        Be the first to know when paid features go live. Founding members get the Dispute Kit at <strong>$29</strong> (regular $39) and Complete Access at <strong>$49</strong>.
      </p>
      <form id="pricing-waitlist-form" style="display:flex; gap:8px; flex-wrap:wrap; justify-content:center;">
        <input id="pricing-waitlist-email" type="email" required placeholder="your@email.com"
          style="flex:1; min-width:220px; padding:12px 16px; border:1.5px solid #CBD5E1; border-radius:10px; font-size:15px; color:#1A2332; font-family:'DM Sans',sans-serif; outline:none;" />
        <button type="submit"
          style="padding:12px 22px; background:#E8A020; color:#1A2332; font-weight:700; border:none; border-radius:10px; font-size:15px; cursor:pointer; font-family:'DM Sans',sans-serif;">
          Notify Me →
        </button>
      </form>
      <div id="pricing-waitlist-success" style="display:none; color:#0F7B8C; font-weight:600; font-size:15px; margin-top:16px;">
        &#10003; You're on the list — we'll email you the moment it goes live.
      </div>
      <script>
        document.getElementById('pricing-waitlist-form').addEventListener('submit', function(e) {
          e.preventDefault();
          var email = document.getElementById('pricing-waitlist-email').value.trim();
          var btn = this.querySelector('button[type="submit"]');
          btn.disabled = true; btn.textContent = 'Sending...';
          if (typeof gtag !== 'undefined') {
            gtag('event', 'waitlist_signup', { event_category: 'conversion', event_label: 'pricing_waitlist', value: 29 });
          }
          fetch('/api/waitlist', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ email: email }) })
            .then(function(r) { return r.json(); })
            .then(function(d) {
              if (d.success) {
                document.getElementById('pricing-waitlist-form').style.display = 'none';
                document.getElementById('pricing-waitlist-success').style.display = 'block';
              } else { btn.disabled = false; btn.textContent = 'Notify Me →'; alert(d.error || 'Please try again.'); }
            })
            .catch(function() { btn.disabled = false; btn.textContent = 'Notify Me →'; alert('Network error.'); });
        });
      </script>
    </div>
  </section>

  <!-- FAQ -->
  <section style="background:#F7F8FA; border-top:1px solid #E2E8F0;" class="py-14 px-4">
    <div class="max-w-2xl mx-auto">
      <h2 class="font-bold text-center mb-10" style="font-size:26px; color:#1A2332;">Pricing Questions</h2>

      <div style="display:flex; flex-direction:column; gap:16px;">

        <div style="background:#fff; border:1px solid #E2E8F0; border-radius:12px; padding:24px 24px;">
          <h3 style="font-size:16px; font-weight:700; color:#1A2332; margin:0 0 10px;">Is the free tier really free forever?</h3>
          <p style="font-size:14px; color:#64748B; margin:0; line-height:1.65;">
            Yes — no credit card, no trial period, no expiry. The free tier (3 EOB decodes and 3 letters per day) is free for life. We built it that way because most people need this tool once or twice, not forever.
          </p>
        </div>

        <div style="background:#fff; border:1px solid #E2E8F0; border-radius:12px; padding:24px 24px;">
          <h3 style="font-size:16px; font-weight:700; color:#1A2332; margin:0 0 10px;">What is the difference between the Dispute Kit and Complete Access?</h3>
          <p style="font-size:14px; color:#64748B; margin:0; line-height:1.65;">
            The Dispute Kit ($29) raises your daily limits to 20 decodes and 20 letters, adds customizable templates and state-specific guides — plenty for a complex dispute. Complete Access ($49) removes all limits entirely, includes unlimited usage, priority processing, and all future features at the founding price.
          </p>
        </div>

        <div style="background:#fff; border:1px solid #E2E8F0; border-radius:12px; padding:24px 24px;">
          <h3 style="font-size:16px; font-weight:700; color:#1A2332; margin:0 0 10px;">When will paid plans be available?</h3>
          <p style="font-size:14px; color:#64748B; margin:0; line-height:1.65;">
            Paid plans are launching soon. Join the waitlist above and you'll be the first to know — and the first to get the founding-member price. The first 100 members get Complete Access at $29 (the Dispute Kit price).
          </p>
        </div>

      </div>
    </div>
  </section>

</Layout>

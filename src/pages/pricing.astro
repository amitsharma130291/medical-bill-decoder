---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Medical Bill Decoder — Pricing"
  description="Simple, honest pricing for Medical Bill Decoder. Free tools forever, plus a 7-Day Pass ($9) and Dispute Kit ($29) for serious disputes."
  canonicalUrl="https://eobdecoder.com/pricing"
>

  <!-- Hero -->
  <section style="background: linear-gradient(135deg, #0F7B8C 0%, #0a6475 100%);" class="py-16 px-4 text-center text-white">
    <div class="max-w-3xl mx-auto">
      <h1 class="font-bold mb-4" style="font-size: 40px; line-height: 1.15;">Free to understand. Pay to fight.</h1>
      <p class="text-teal-100 mb-2" style="font-size: 18px; line-height: 1.6;">
        Start free. Upgrade only when you need more firepower.
      </p>
      <p class="text-teal-200" style="font-size: 14px;">No subscriptions. No surprises. No gotchas.</p>
    </div>
  </section>

  <!-- Pricing Cards -->
  <section class="py-16 px-4" style="background: #F7F8FA;">
    <div class="max-w-5xl mx-auto">

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

        <!-- Free Tier -->
        <div style="background:#fff; border:1.5px solid #E2E8F0; border-radius:16px; padding:32px 28px; position:relative; display:flex; flex-direction:column;">
          <div style="font-size:13px; font-weight:600; color:#64748B; text-transform:uppercase; letter-spacing:0.07em; margin-bottom:12px;">Free</div>
          <div style="font-size:42px; font-weight:800; color:#1A2332; line-height:1; margin-bottom:6px;">$0</div>
          <div style="font-size:14px; color:#64748B; margin-bottom:24px;">Forever free</div>
          <ul style="list-style:none; padding:0; margin:0 0 32px; flex:1;">
            <li style="display:flex; align-items:flex-start; gap:10px; margin-bottom:12px; font-size:14px; color:#334155;">
              <span style="color:#0F7B8C; font-weight:700; margin-top:1px;">✓</span>
              <span>EOB Decoder — 3 decodes per day</span>
            </li>
            <li style="display:flex; align-items:flex-start; gap:10px; margin-bottom:12px; font-size:14px; color:#334155;">
              <span style="color:#0F7B8C; font-weight:700; margin-top:1px;">✓</span>
              <span>Dispute Letter Generator — 3 letters per day</span>
            </li>
            <li style="display:flex; align-items:flex-start; gap:10px; margin-bottom:12px; font-size:14px; color:#334155;">
              <span style="color:#0F7B8C; font-weight:700; margin-top:1px;">✓</span>
              <span>Billing Error Checklist (full access)</span>
            </li>
            <li style="display:flex; align-items:flex-start; gap:10px; margin-bottom:12px; font-size:14px; color:#334155;">
              <span style="color:#0F7B8C; font-weight:700; margin-top:1px;">✓</span>
              <span>No account required</span>
            </li>
          </ul>
          <a href="/eob-decoder" style="display:block; text-align:center; padding:13px 20px; border:2px solid #0F7B8C; border-radius:10px; color:#0F7B8C; font-weight:700; font-size:15px; text-decoration:none; transition:background 0.15s;" onmouseover="this.style.background='#F0FAFB'" onmouseout="this.style.background='transparent'">
            Start Free →
          </a>
        </div>


        <!-- 7-Day Session Pass -->
        <div style="background:#fff; border:2.5px solid #059669; border-radius:16px; padding:32px 28px; position:relative; display:flex; flex-direction:column; box-shadow: 0 8px 36px rgba(5,150,105,0.14);">
          <!-- MOST POPULAR ribbon -->
          <div style="position:absolute; top:-13px; left:50%; transform:translateX(-50%); background:#059669; color:#fff; font-size:12px; font-weight:700; padding:4px 16px; border-radius:999px; white-space:nowrap; letter-spacing:0.06em;">
            MOST POPULAR
          </div>
          <div style="font-size:13px; font-weight:600; color:#059669; text-transform:uppercase; letter-spacing:0.07em; margin-bottom:12px;">7-Day Pass</div>
          <!-- Urgency badge -->
          <div style="display:inline-block; background:#ECFDF5; color:#065F46; font-size:11px; font-weight:700; padding:3px 10px; border-radius:999px; margin-bottom:10px; width:fit-content;">⚡ Most people resolve their bill within 7 days</div>
          <div style="font-size:42px; font-weight:800; color:#1A2332; line-height:1; margin-bottom:4px;">$9</div>
          <div style="font-size:13px; color:#64748B; font-style:italic; margin-bottom:4px;">The average disputed bill saves $400+</div>
          <div style="font-size:14px; color:#64748B; margin-bottom:24px;">One-time payment</div>
          <ul style="list-style:none; padding:0; margin:0 0 28px; flex:1;">
            <li style="display:flex; align-items:flex-start; gap:10px; margin-bottom:12px; font-size:14px; color:#334155;">
              <span style="color:#059669; font-weight:700; margin-top:1px;">✓</span>
              <span>Decode every EOB from this billing event — unlimited this week</span>
            </li>
            <li style="display:flex; align-items:flex-start; gap:10px; margin-bottom:12px; font-size:14px; color:#334155;">
              <span style="color:#059669; font-weight:700; margin-top:1px;">✓</span>
              <span>Full dispute strategy for each denial code found</span>
            </li>
            <li style="display:flex; align-items:flex-start; gap:10px; margin-bottom:12px; font-size:14px; color:#334155;">
              <span style="color:#059669; font-weight:700; margin-top:1px;">✓</span>
              <span>20 dispute letters per day</span>
            </li>
            <li style="display:flex; align-items:flex-start; gap:10px; margin-bottom:12px; font-size:14px; color:#334155;">
              <span style="color:#059669; font-weight:700; margin-top:1px;">✓</span>
              <span>Expires in 7 days — built for one billing event</span>
            </li>
            <li style="display:flex; align-items:flex-start; gap:10px; margin-bottom:12px; font-size:14px; color:#94A3B8;">
              <span style="color:#94A3B8; font-weight:700; margin-top:1px;">✗</span>
              <span>No PDF download (available in Dispute Kit)</span>
            </li>
          </ul>
          <a href="https://amitverse58.gumroad.com/l/vluqnh" target="_blank" rel="noopener"
            style="display:block; text-align:center; padding:13px 20px; background:#059669; border-radius:10px; color:#fff; font-weight:700; font-size:15px; text-decoration:none;"
            onmouseover="this.style.background='#047857'" onmouseout="this.style.background='#059669'"
            onclick="if(typeof gtag!=='undefined'){gtag('event','gumroad_buy_click',{event_category:'conversion',event_label:'session_pass_pricing',value:9})}">
            Buy Now — $9 →
          </a>
          <div style="text-align:center; font-size:12px; color:#64748B; margin-top:8px;">Access starts immediately. Works for any US medical bill.</div>
          <a href="/activate" style="display:block; text-align:center; padding:10px 20px; color:#64748B; font-size:13px; font-weight:600; text-decoration:none; margin-top:6px;">
            Already purchased? Activate key →
          </a>
        </div>

        <!-- Dispute Kit -->
        <div style="background:#fff; border:2px solid #0F7B8C; border-radius:16px; padding:32px 28px; position:relative; display:flex; flex-direction:column; box-shadow: 0 8px 32px rgba(15,123,140,0.12);">
          <!-- Live badge -->
          <div style="position:absolute; top:-12px; left:50%; transform:translateX(-50%); background:#059669; color:#fff; font-size:12px; font-weight:700; padding:4px 14px; border-radius:999px; white-space:nowrap; letter-spacing:0.04em;">
            NOW LIVE
          </div>
          <div style="font-size:13px; font-weight:600; color:#0F7B8C; text-transform:uppercase; letter-spacing:0.07em; margin-bottom:12px;">Dispute Kit</div>
          <!-- Urgency badge -->
          <div style="display:inline-block; background:#FEF3C7; color:#92400E; font-size:11px; font-weight:700; padding:3px 10px; border-radius:999px; margin-bottom:10px; width:fit-content;">🔥 Introductory Price</div>
          <div style="display:flex; align-items:baseline; gap:10px; margin-bottom:4px;">
            <span style="font-size:42px; font-weight:800; color:#1A2332; line-height:1;">$29</span>
            <span style="font-size:18px; color:#94A3B8; text-decoration:line-through;">$39</span>
          </div>
          <div style="font-size:13px; color:#92400E; font-weight:600; margin-bottom:4px;">Price increases as we add more features</div>
          <div style="font-size:14px; color:#64748B; margin-bottom:6px;">One-time payment</div>
          <div style="font-size:14px; color:#334155; font-style:italic; margin-bottom:18px;">Understand and fight your medical bill</div>
          <ul style="list-style:none; padding:0; margin:0 0 32px; flex:1;">
            <li style="display:flex; align-items:flex-start; gap:10px; margin-bottom:12px; font-size:14px; color:#334155;">
              <span style="color:#0F7B8C; font-weight:700; margin-top:1px;">✓</span>
              <span>Decode your EOB in plain English</span>
            </li>
            <li style="display:flex; align-items:flex-start; gap:10px; margin-bottom:12px; font-size:14px; color:#334155;">
              <span style="color:#0F7B8C; font-weight:700; margin-top:1px;">✓</span>
              <span>Full dispute strategy — step-by-step next steps, not just a summary</span>
            </li>
            <li style="display:flex; align-items:flex-start; gap:10px; margin-bottom:12px; font-size:14px; color:#334155;">
              <span style="color:#0F7B8C; font-weight:700; margin-top:1px;">✓</span>
              <span>Download as PDF</span>
            </li>
            <li style="display:flex; align-items:flex-start; gap:10px; margin-bottom:12px; font-size:14px; color:#334155;">
              <span style="color:#0F7B8C; font-weight:700; margin-top:1px;">✓</span>
              <span>20 EOB decodes/day · 20 letters/day</span>
            </li>
          </ul>
          <a href="https://amitverse58.gumroad.com/l/fsupd" target="_blank" rel="noopener"
            style="display:block; text-align:center; padding:13px 20px; background:#0F7B8C; border-radius:10px; color:#fff; font-weight:700; font-size:15px; text-decoration:none;"
            onmouseover="this.style.background='#0a6475'" onmouseout="this.style.background='#0F7B8C'"
            onclick="if(typeof gtag!=='undefined'){gtag('event','gumroad_buy_click',{event_category:'conversion',event_label:'dispute_kit_pricing',value:29})}">
            Buy Now — $29 →
          </a>
          <a href="/activate" style="display:block; text-align:center; padding:10px 20px; color:#64748B; font-size:13px; font-weight:600; text-decoration:none; margin-top:10px;">
            Already purchased? Activate key →
          </a>
        </div>


      </div>



    </div>
  </section>

  <!-- FAQ -->
  <section style="background:#F7F8FA; border-top:1px solid #E2E8F0;" class="py-14 px-4">
    <div class="max-w-2xl mx-auto">
      <h2 class="font-bold text-center mb-10" style="font-size:26px; color:#1A2332;">Pricing Questions</h2>

      <div style="display:flex; flex-direction:column; gap:16px;">

        <div style="background:#fff; border:1px solid #E2E8F0; border-radius:12px; padding:24px 24px;">
          <h3 style="font-size:16px; font-weight:700; color:#1A2332; margin:0 0 10px;">Is the free tier really free forever?</h3>
          <p style="font-size:14px; color:#64748B; margin:0; line-height:1.65;">
            Yes — no credit card, no trial period, no expiry. The free tier (3 EOB decodes and 3 letters per day) is free for life. We built it that way because most people need this tool once or twice, not forever.
          </p>
        </div>

        <div style="background:#fff; border:1px solid #E2E8F0; border-radius:12px; padding:24px 24px;">
          <h3 style="font-size:16px; font-weight:700; color:#1A2332; margin:0 0 10px;">What is the difference between the 7-Day Pass and the Dispute Kit?</h3>
          <p style="font-size:14px; color:#64748B; margin:0; line-height:1.65;">
            The 7-Day Pass ($9) gives you full access for 7 days — 20 decodes and 20 letters per day. It is perfect for a single dispute you need to resolve quickly. The Dispute Kit ($29) gives you the same daily limits but your access does not expire after 7 days, so you can come back whenever another bill arrives.
          </p>
        </div>

        <div style="background:#fff; border:1px solid #E2E8F0; border-radius:12px; padding:24px 24px;">
          <h3 style="font-size:16px; font-weight:700; color:#1A2332; margin:0 0 10px;">Are paid plans available now?</h3>
          <p style="font-size:14px; color:#64748B; margin:0; line-height:1.65;">
            Yes — both the 7-Day Pass ($9) and the Dispute Kit ($29) are live now. Click any "Buy Now" button above to purchase instantly via Gumroad.
          </p>
        </div>

      </div>
    </div>
  </section>

</Layout>

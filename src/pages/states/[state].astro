---
import { getCollection, type CollectionEntry } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export const prerender = true;

export async function getStaticPaths() {
  const states = await getCollection('states');
  return states.map((entry) => ({
    params: { state: entry.slug },
    props: { entry },
  }));
}

type Props = {
  entry: CollectionEntry<'states'>;
};

const { entry } = Astro.props;
const { Content } = await entry.render();
---
<Layout title={entry.data.title} description={entry.data.description}>
  <article class="max-w-3xl mx-auto px-4 py-16">
    <nav class="text-sm text-gray-400 mb-6">
      <a href="/" class="hover:text-brand-600">Home</a>
      <span class="mx-2">/</span>
      <span>States</span>
      <span class="mx-2">/</span>
      <span class="text-gray-700">{entry.data.state}</span>
    </nav>

    <div class="flex items-center gap-4 mb-6">
      <span class="text-4xl font-mono font-bold text-brand-200 bg-brand-700 px-4 py-2 rounded-xl">{entry.data.stateCode}</span>
      <h1 class="text-4xl font-extrabold text-gray-900">{entry.data.title}</h1>
    </div>

    <p class="text-xl text-gray-500 mb-10">{entry.data.description}</p>

    <div class="prose prose-lg max-w-none">
      <Content />
    </div>

    <div class="mt-12 p-6 bg-brand-50 rounded-2xl border border-brand-100">
      <h2 class="font-bold text-brand-900 mb-2">Generate a {entry.data.state}-specific Dispute Letter</h2>
      <p class="text-brand-700 text-sm mb-4">Our dispute letter generator includes {entry.data.state} state references automatically.</p>
      <a href="/dispute-letter" class="inline-block bg-brand-600 text-white font-semibold px-6 py-3 rounded-xl hover:bg-brand-700 transition-colors">
        Generate Dispute Letter →
      </a>
    </div>
  </article>
</Layout>

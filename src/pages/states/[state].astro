---
import { getCollection, type CollectionEntry } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export const prerender = true;

export async function getStaticPaths() {
  const states = await getCollection('states');
  return states.map((entry) => ({
    params: { state: entry.slug },
    props: { entry },
  }));
}

type Props = {
  entry: CollectionEntry<'states'>;
};

const { entry } = Astro.props;
const { Content } = await entry.render();

// Extract state name from title (e.g. "Medical Bill Disputes in California: ...")
function extractStateName(title: string): string {
  const match = title.match(/in ([^:]+):/);
  return match ? match[1].trim() : title;
}

// Extract FAQ pairs from raw body using ## FAQ section
function extractFAQs(body: string) {
  const faqStart = body.indexOf('\n## FAQ\n');
  if (faqStart === -1) return [];
  const faqSection = body.slice(faqStart + 8);
  const pairs: { question: string; answer: string }[] = [];
  const lines = faqSection.split('\n');
  let i = 0;
  while (i < lines.length) {
    const qMatch = lines[i].match(/^\*\*Q:\s*(.*?)\*\*$/);
    if (qMatch) {
      const question = qMatch[1].trim();
      let answer = '';
      i++;
      while (i < lines.length && !lines[i].match(/^\*\*Q:/)) {
        const ansLine = lines[i].replace(/^A:\s*/, '').trim();
        if (ansLine) answer += (answer ? ' ' : '') + ansLine;
        i++;
      }
      if (question && answer) pairs.push({ question, answer });
    } else {
      i++;
    }
  }
  return pairs;
}

const stateName = extractStateName(entry.data.title);
const faqs = extractFAQs(entry.body || '');

const faqJsonLd = faqs.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(faq => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.answer,
    },
  })),
} : null;
---
<Layout title={entry.data.title} description={entry.data.description} canonicalUrl={new URL(Astro.url.pathname, import.meta.env.SITE_URL ?? 'https://eobdecoder.com').href}>
  {faqJsonLd && (
    <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />
  )}

  <!-- Hero header with teal gradient -->
  <div class="bg-gradient-to-br from-teal-700 via-teal-600 to-cyan-600 text-white">
    <div class="max-w-3xl mx-auto px-4 py-12 sm:py-16">
      <!-- Breadcrumb -->
      <nav class="text-sm text-teal-200 mb-6" aria-label="Breadcrumb">
        <a href="/" class="hover:text-white transition-colors">Home</a>
        <span class="mx-2 text-teal-400">›</span>
        <a href="/states" class="hover:text-white transition-colors">State Guides</a>
        <span class="mx-2 text-teal-400">›</span>
        <span class="text-white">{stateName}</span>
      </nav>
      <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight mb-4 leading-tight">
        {entry.data.title}
      </h1>
      {entry.data.description && (
        <p class="text-lg sm:text-xl text-teal-100 leading-relaxed max-w-2xl">
          {entry.data.description}
        </p>
      )}
    </div>
  </div>

  <!-- Article body -->
  <div class="max-w-3xl mx-auto px-4 py-10 sm:py-14">
    <article
      class="
        prose prose-lg max-w-none
        prose-headings:font-bold prose-headings:text-gray-900
        prose-h2:text-2xl prose-h2:mt-10 prose-h2:mb-4 prose-h2:pt-6 prose-h2:border-t prose-h2:border-gray-200
        prose-h3:text-xl prose-h3:mt-8 prose-h3:mb-3
        prose-p:text-gray-700 prose-p:leading-relaxed
        prose-a:text-teal-700 prose-a:font-medium hover:prose-a:text-teal-900
        prose-strong:text-gray-900
        prose-ul:my-4 prose-li:my-1 prose-li:text-gray-700
        prose-ol:my-4
        prose-blockquote:border-l-4 prose-blockquote:border-teal-500 prose-blockquote:bg-teal-50 prose-blockquote:py-1 prose-blockquote:px-4 prose-blockquote:rounded-r-lg prose-blockquote:not-italic
        prose-table:border-collapse prose-table:w-full
        prose-th:bg-gray-100 prose-th:px-4 prose-th:py-2 prose-th:text-left prose-th:border prose-th:border-gray-300
        prose-td:px-4 prose-td:py-2 prose-td:border prose-td:border-gray-200
        prose-code:bg-gray-100 prose-code:text-teal-700 prose-code:rounded prose-code:px-1
        prose-pre:bg-gray-900 prose-pre:rounded-xl
      "
    >
      <Content />
    </article>

    <!-- State-specific CTA -->
    <div class="mt-12 p-6 bg-teal-50 rounded-2xl border border-teal-100">
      <h2 class="font-bold text-teal-900 text-lg mb-2">Generate a {stateName}-specific Dispute Letter</h2>
      <p class="text-teal-700 text-sm mb-4">Our dispute letter generator includes {stateName} state references automatically.</p>
      <a href="/dispute-letter" class="inline-block bg-teal-700 text-white font-semibold px-6 py-3 rounded-xl hover:bg-teal-800 transition-colors">
        Generate Dispute Letter →
      </a>
    </div>
  </div>
</Layout>

---
import { getCollection, type CollectionEntry } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export const prerender = true;

export async function getStaticPaths() {
  const states = await getCollection('states');
  return states.map((entry) => ({
    params: { state: entry.slug },
    props: { entry },
  }));
}

type Props = {
  entry: CollectionEntry<'states'>;
};

const { entry } = Astro.props;
const { Content } = await entry.render();

// Extract state name from title (e.g. "Medical Bill Disputes in California: ...")
function extractStateName(title: string): string {
  const match = title.match(/in ([^:]+):/);
  return match ? match[1].trim() : title;
}

// Extract FAQ pairs from raw body using ## FAQ section
function extractFAQs(body: string) {
  const faqStart = body.indexOf('\n## FAQ\n');
  if (faqStart === -1) return [];
  const faqSection = body.slice(faqStart + 8);
  const pairs: { question: string; answer: string }[] = [];
  const lines = faqSection.split('\n');
  let i = 0;
  while (i < lines.length) {
    const qMatch = lines[i].match(/^\*\*Q:\s*(.*?)\*\*$/);
    if (qMatch) {
      const question = qMatch[1].trim();
      let answer = '';
      i++;
      while (i < lines.length && !lines[i].match(/^\*\*Q:/)) {
        const ansLine = lines[i].replace(/^A:\s*/, '').trim();
        if (ansLine) answer += (answer ? ' ' : '') + ansLine;
        i++;
      }
      if (question && answer) pairs.push({ question, answer });
    } else {
      i++;
    }
  }
  return pairs;
}

const stateName = extractStateName(entry.data.title);
const faqs = extractFAQs(entry.body || '');

const faqJsonLd = faqs.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(faq => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.answer,
    },
  })),
} : null;
---
<Layout title={entry.data.title} description={entry.data.description} canonicalUrl={new URL(Astro.url.pathname, import.meta.env.SITE_URL ?? 'https://eobdecoder.com').href}>
  {faqJsonLd && (
    <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />
  )}
  <article class="max-w-3xl mx-auto px-4 py-16">
    <nav class="text-sm text-gray-400 mb-6">
      <a href="/" class="hover:text-brand-600">Home</a>
      <span class="mx-2">/</span>
      <span>States</span>
      <span class="mx-2">/</span>
      <span class="text-gray-700">{stateName}</span>
    </nav>

    <h1 class="text-4xl font-extrabold text-gray-900 mb-6">{entry.data.title}</h1>
    <p class="text-xl text-gray-500 mb-10">{entry.data.description}</p>

    <div class="prose prose-lg max-w-none">
      <Content />
    </div>

    <div class="mt-12 p-6 bg-blue-50 rounded-2xl border border-blue-100">
      <h2 class="font-bold text-blue-900 mb-2">Generate a {stateName}-specific Dispute Letter</h2>
      <p class="text-blue-700 text-sm mb-4">Our dispute letter generator includes {stateName} state references automatically.</p>
      <a href="/dispute-letter" class="inline-block bg-blue-700 text-white font-semibold px-6 py-3 rounded-xl hover:bg-blue-800 transition-colors">
        Generate Dispute Letter →
      </a>
    </div>
  </article>
</Layout>

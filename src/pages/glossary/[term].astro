---
import { getCollection, type CollectionEntry } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export const prerender = true;

export async function getStaticPaths() {
  const terms = await getCollection('glossary');
  return terms.map((entry) => ({
    params: { term: entry.slug },
    props: { entry },
  }));
}

type Props = {
  entry: CollectionEntry<'glossary'>;
};

const { entry } = Astro.props;
const { Content, remarkPluginFrontmatter } = await entry.render();

// Extract FAQ pairs from raw body using ## FAQ section
function extractFAQs(body: string) {
  const faqStart = body.indexOf('\n## FAQ\n');
  if (faqStart === -1) return [];
  const faqSection = body.slice(faqStart + 8);
  const pairs: { question: string; answer: string }[] = [];
  const lines = faqSection.split('\n');
  let i = 0;
  while (i < lines.length) {
    const qMatch = lines[i].match(/^\*\*Q:\s*(.*?)\*\*$/);
    if (qMatch) {
      const question = qMatch[1].trim();
      let answer = '';
      i++;
      // Collect answer lines until next Q or end
      while (i < lines.length && !lines[i].match(/^\*\*Q:/)) {
        const ansLine = lines[i].replace(/^A:\s*/, '').trim();
        if (ansLine) answer += (answer ? ' ' : '') + ansLine;
        i++;
      }
      if (question && answer) pairs.push({ question, answer });
    } else {
      i++;
    }
  }
  return pairs;
}

const faqs = extractFAQs(entry.body || '');

const faqJsonLd = faqs.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(faq => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.answer,
    },
  })),
} : null;
---
<Layout title={entry.data.title} description={entry.data.description} canonicalUrl={new URL(Astro.url.pathname, import.meta.env.SITE_URL ?? 'https://medicalbilldecoder.com').href}>
  {faqJsonLd && (
    <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />
  )}
  <article class="max-w-3xl mx-auto px-4 py-16">
    <nav class="text-sm text-gray-400 mb-6">
      <a href="/" class="hover:text-brand-600">Home</a>
      <span class="mx-2">/</span>
      <span>Glossary</span>
      <span class="mx-2">/</span>
      <span class="text-gray-700">{entry.data.title}</span>
    </nav>

    <h1 class="text-4xl font-extrabold text-gray-900 mb-4">{entry.data.title}</h1>
    <p class="text-xl text-gray-500 mb-10">{entry.data.description}</p>

    <div class="prose prose-lg max-w-none">
      <Content />
    </div>
  </article>
</Layout>

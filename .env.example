# Paddle Billing
# Get these from https://vendors.paddle.com (live) or https://sandbox-vendors.paddle.com (sandbox)
PADDLE_CLIENT_TOKEN=test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
PADDLE_PRICE_ID=pri_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
PADDLE_WEBHOOK_SECRET=pdl_ntfset_xxxxxxxxxxxxxxxxxxxx
# Set to "sandbox" for testing, remove or set to "production" for live
PADDLE_ENV=sandbox

# Site
SITE_URL=https://eobdecoder.com

# OpenAI
OPENAI_API_KEY=your_openai_api_key

# Google Analytics 4 (optional — set to activate tracking)
GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Web3Forms (email notifications for waitlist — zero config, no domain verification needed)
# Get your free access key at https://web3forms.com/ — enter your email, key arrives instantly.
# Set this in Vercel env vars. The client-side form call fires from the user's browser (free plan).
WEB3FORMS_ACCESS_KEY=your-web3forms-access-key-uuid

# Resend (transactional email — activation emails after Gumroad purchase)
# Get your API key at https://resend.com/api-keys
# Must also verify your sending domain (eobdecoder.com) in Resend dashboard
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
